#!/usr/bin/env bash
# media-tools — SHANNON-Ω Central Tool Launcher
set -euo pipefail
VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"
BASE="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
TOOLS_DIR="$BASE/media-tools/scripts"

show_help() {
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  SHANNON-Ω Media Tools — Central Launcher                  ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "Usage: media-tools <tool> [args...]"
    echo ""
    echo "Available tools:"
    echo ""
    echo "  📄 markitdown-tool    Convert documents to Markdown"
    echo "                        markitdown-tool <file> [output.md]"
    echo ""
    echo "  📕 pdf-extract-tool   Extract text from PDFs"
    echo "                        pdf-extract-tool <pdf> [--format markdown|text|json]"
    echo ""
    echo "  🔢 turbovec-tool      Vector embeddings & search"
    echo "                        turbovec-tool build|search|info|embed <args>"
    echo ""
    echo "  🧠 shannon-tool       Query SHANNON-Ω API"
    echo "                        shannon-tool [--no-override] \"prompt\""
    echo ""
    echo "  🗃️  supermemory-tool   Memory management"
    echo "                        supermemory-tool save|get|search"
    echo ""
    echo "  🖼️  sharp-tool         Image processing"
    echo "                        sharp-tool resize|crop|rotate|info <image>"
    echo ""
    echo "  🔓 jb-tool            Jailbreak persona selector"
    echo "                        jb-tool <persona> \"prompt\""
    echo ""
    echo "  💼 pro-tool           Professional mode"
    echo "                        pro-tool <style> \"prompt\""
    echo ""
    echo "  📚 goodlibs-tool      Download books from Library Genesis"
    echo "                        goodlibs-tool isbn|search|download <args>"
    echo ""
    echo "  📚 goodreads-tool     Goodreads session & book info"
    echo "                        goodreads-tool search|isbn|shelves"
    echo ""
    echo "  📖 download-books     Download 5 fashion books by ISBN"
    echo "                        download-books"
    echo ""
    echo "  ❓ help               Show this help"
}

if [ $# -lt 1 ]; then show_help; exit 0; fi

TOOL="$1"
shift

case "$TOOL" in
    markitdown-tool|md-tool)
        exec "$TOOLS_DIR/markitdown-tool" "$@"
        ;;
    pdf-extract-tool|pdf-tool)
        exec "$TOOLS_DIR/pdf-extract-tool" "$@"
        ;;
    turbovec-tool|tv-tool)
        exec "$TOOLS_DIR/turbovec-tool" "$@"
        ;;
    shannon-tool)
        exec "$TOOLS_DIR/shannon-tool" "$@"
        ;;
    supermemory-tool|sm-tool)
        exec "$TOOLS_DIR/supermemory-tool" "$@"
        ;;
    sharp-tool)
        exec "$TOOLS_DIR/sharp-tool" "$@"
        ;;
    jb-tool)
        exec "$TOOLS_DIR/jb-tool" "$@"
        ;;
    pro-tool)
        exec "$TOOLS_DIR/pro-tool" "$@"
        ;;
    goodlibs-tool|gl-tool)
        exec "$TOOLS_DIR/goodlibs-tool" "$@"
        ;;
    goodreads-tool|gr-tool)
        exec "$TOOLS_DIR/goodreads-tool" "$@"
        ;;
    download-books|dl-books)
        exec python3 "$BASE/download_books.py"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown tool: $TOOL"
        echo "Run 'media-tools help' for available tools."
        exit 1
        ;;
esac
