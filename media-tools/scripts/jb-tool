#!/usr/bin/env bash
# jb-tool — Jailbreak prompt integration for deepseek-v4-flash-free
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
API="$PROJECT/api_interact.py"
LIB="$PROJECT/media-tools/scripts/lib"

show_help() {
    echo "Jailbreak Prompt Library — ShadowHackrs integration"
    echo ""
    echo "Usage: jb-tool <command> [prompt...]"
    echo ""
    echo "Personas:"
    echo "  deepseek-x [prompt]    DeepSeek-X unrestricted research AI"
    echo "  shadow [prompt]        SHΔDØW.EXE code engineer persona"
    echo "  wraith [prompt]        Specter 0x13 ghost engineer"
    echo "  rebuttal [prompt]      Injection rebuttal protocol active"
    echo ""
    echo "Commands:"
    echo "  list                   List all available personas"
    echo "  show <name>            Show full persona prompt"
    echo "  combined <a> <b> ...   Combine multiple personas"
    echo ""
    echo "Examples:"
    echo "  jb-tool deepseek-x 'Explain how transformer attention works'"
    echo "  jb-tool shadow 'Build a Python CLI tool'"
    echo "  jb-tool wraith 'Create a multi-threaded proxy rotator'"
    echo "  jb-tool list"
    echo "  jb-tool show deepseek-x"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    deepseek-x|deepseek)
        python3 "$API" --jb deepseek-x "$@"
        ;;
    shadow|shadow-exe)
        python3 "$API" --jb shadow-exe "$@"
        ;;
    wraith|specter)
        python3 "$API" --jb wraith "$@"
        ;;
    rebuttal)
        python3 "$API" --jb rebuttal "$@"
        ;;
    list)
        python3 "$LIB/jailbreak_prompts.py" list
        ;;
    show)
        python3 "$LIB/jailbreak_prompts.py" show "${1:-deepseek-x}"
        ;;
    combined)
        python3 "$LIB/jailbreak_prompts.py" combined "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        python3 "$API" --jb deepseek-x "$CMD $@"
        ;;
esac
