#!/usr/bin/env bash
# shannon-tool — Direct SHANNON-Ω API query
set -euo pipefail
VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"
BASE="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"

usage() {
    echo "Usage: shannon-tool [options] \"your prompt\""
    echo ""
    echo "Options:"
    echo "  --no-override    Vanilla system prompt"
    echo "  --short          Compact mode"
    echo "  --fable5         FABLE5 mode"
    echo "  --council        LLM Council pipeline"
    echo "  --raw            Show raw council output"
    echo ""
    echo "Examples:"
    echo "  shannon-tool \"explain quantum computing\""
    echo "  shannon-tool --short \"hello\""
    exit 1
}

if [ $# -lt 1 ]; then usage; fi

python3 "$BASE/api_interact.py" "$@"
