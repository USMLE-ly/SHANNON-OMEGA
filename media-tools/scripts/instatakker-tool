#!/usr/bin/env bash
# instatakker-tool — Instagram engagement workflow manager
set -euo pipefail

PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
INSTADIR="$PROJECT/instatakker"
XVFB_PID_FILE="/tmp/instatakker-xvfb.pid"

show_help() {
    echo "InstaTakker — Instagram Engagement Workflow Manager"
    echo ""
    echo "Usage: instatakker-tool <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  start          Launch InstaTakker GUI (auto-starts virtual display)"
    echo "  info           Show app info and version"
    echo "  status         Check if instatakker is installed"
    echo "  core <action>  Run headless automation (login|like|unfollow)"
    echo "  screen         Take a screenshot of the app window"
    echo ""
    echo "Examples:"
    echo "  instatakker-tool start    # Launches with Xvfb if no display"
    echo "  instatakker-tool info"
}

ensure_display() {
    if [ -z "${DISPLAY:-}" ]; then
        echo "ℹ️  No display found, starting virtual display (Xvfb)..."
        Xvfb :99 -screen 0 1280x720x24 &>/tmp/xvfb.log &
        echo $! > "$XVFB_PID_FILE"
        sleep 1
        export DISPLAY=:99
        echo "   Virtual display :99 ready"
    fi
}

cleanup_display() {
    if [ -f "$XVFB_PID_FILE" ]; then
        kill "$(cat "$XVFB_PID_FILE")" 2>/dev/null || true
        rm -f "$XVFB_PID_FILE"
    fi
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    start)
        if [ ! -f "$INSTADIR/node_modules/electron/dist/electron" ]; then
            echo "❌ Electron not found. Run: cd $INSTADIR && npm install"
            exit 1
        fi
        ensure_display
        cd "$INSTADIR"
        echo "🚀 Launching InstaTakker..."
        echo "   (Close the app window or press Ctrl+C to stop)"
        echo ""
        npx electron . --no-sandbox --disable-gpu 2>&1
        cleanup_display
        ;;
    info)
        cd "$INSTADIR"
        VERSION=$(node -e "console.log(require('./package.json').version)")
        echo "InstaTakker v$VERSION"
        echo "Description: $(node -e "console.log(require('./package.json').description)")"
        echo "Location: $INSTADIR"
        echo "Electron: $(node -e "console.log(require('./node_modules/electron/package.json').version)" 2>/dev/null || echo 'not installed')"
        echo ""
        echo "Files:"
        ls -lh "$INSTADIR"/*.js "$INSTADIR/index.html" "$INSTADIR/styles.css" 2>/dev/null
        ;;
    status)
        if [ -d "$INSTADIR" ]; then
            echo "✅ InstaTakker installed at $INSTADIR"
            echo "   Version: $(node -e "console.log(require('$INSTADIR/package.json').version)" 2>/dev/null || echo '?')"
            if [ -f "$INSTADIR/node_modules/electron/dist/electron" ]; then
                echo "   Electron: ready"
            else
                echo "   Electron: not installed (run: cd $INSTADIR && npm install)"
            fi
        else
            echo "❌ InstaTakker not installed"
        fi
        ;;
    screen)
        ensure_display
        if ! command -v import &>/dev/null; then
            echo "📸 Installing imagemagick for screenshots..."
            apt-get install -y -qq imagemagick 2>/dev/null
        fi
        if command -v import &>/dev/null; then
            import -display :99 -window root /tmp/instatakker-screenshot.png 2>/dev/null && \
                echo "📸 Screenshot saved: /tmp/instatakker-screenshot.png" || \
                echo "⚠️  Screenshot failed (app may not be running)"
        else
            echo "⚠️  Screenshot tool not available"
        fi
        cleanup_display
        ;;
    core)
        echo "ℹ️  Headless mode requires running instatakker-core.js directly:"
        echo "   node $INSTADIR/instatakker-core.js [action]"
        echo ""
        echo "Note: This requires Instagram credentials and browser automation."
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $CMD"
        show_help
        exit 1
        ;;
esac
