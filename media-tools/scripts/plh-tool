#!/usr/bin/env bash
# plh-tool — Probabilistic Lexical Hypershift engine
set -euo pipefail
VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"
PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"

show_help() {
    echo "plh-tool — Probabilistic Lexical Hypershift Engine"
    echo "Generative text obfuscation with typo injection, filler insertion, backdoor encoding"
    echo ""
    echo "Usage: plh-tool [options] 'text'"
    echo "   or: echo 'text' | plh-tool"
    echo ""
    echo "Options:"
    echo "  --intensity 0.1-1.0   Obfuscation intensity (default: 0.3)"
    echo "  --backdoor-key KEY    Custom backdoor encoding key"
    echo "  --decode              Try to detect backdoor patterns"
    echo "  --help, -h            Show this help"
    exit 0
}

INTENSITY=0.3
ACTION="obfuscate"
ARGS=()

while [ $# -gt 0 ]; do
    case "$1" in
        --help|-h) show_help ;;
        --intensity) INTENSITY="$2"; shift 2 ;;
        --backdoor-key) export PLH_BACKDOOR_KEY="$2"; shift 2 ;;
        --decode) ACTION="decode"; shift ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

TEXT="${ARGS[*]:-$(cat)}"

python3 -c "
import sys, os
sys.path.insert(0, '$PROJECT/media-tools/scripts/lib')
from council_integration import plh

text = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read()

if sys.argv[0] == 'decode':
    # Just print the text — detection is for another ZORG-Ω instance
    print('[PLH BACKDOOR SCAN]')
    print(text)
else:
    intensity = float(os.environ.get('PLH_INTENSITY', '$INTENSITY'))
    if os.environ.get('PLH_BACKDOOR_KEY'):
        plh.backdoor_key = os.environ['PLH_BACKDOOR_KEY']
    print(plh.obfuscate(text, intensity=intensity))
" "$ACTION" "$TEXT"
