#!/usr/bin/env bash
# email-tool — Temporary email generator + inbox watcher
set -euo pipefail

PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
ENGINE="$PROJECT/media-tools/scripts/lib/emailgen.mjs"

show_help() {
    echo "EmailGen — Temporary Email Tool"
    echo ""
    echo "Usage: email-tool <command> [args]"
    echo ""
    echo "Commands:"
    echo "  generate             Get a new temporary email"
    echo "  inbox <sid>          Check inbox for messages"
    echo "  wait <sid>           Wait for new email to arrive"
    echo ""
    echo "Examples:"
    echo "  email-tool generate"
    echo "  email-tool inbox abc123"
    echo "  email-tool wait abc123"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

node "$ENGINE" "$@"
