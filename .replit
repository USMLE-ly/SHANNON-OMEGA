run = "pip install gunicorn flask flask-cors requests python-dotenv Pillow qdrant-client --break-system-packages && gunicorn main:app --bind 0.0.0.0:5000 --timeout 120 --worker-tmp-dir /dev/shm --preload"
modules = ["python-3.11"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--preload", "--timeout=120", "main:app"]

[[ports]]
localPort = 5000
externalPort = 80
