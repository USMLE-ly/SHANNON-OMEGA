{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "luxor-hub/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "cd luxor-hub && npm install",
        "buildCommand": "cd luxor-hub && npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
