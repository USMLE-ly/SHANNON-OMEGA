# Luxor Pro Stylist Tweaks - Environment Configuration
# 
# Pipeline Modes:
#   FORCE_LOCAL_ONLY=1 (default) → Uses deterministic local stylist (instant, no API needed)
#   FORCE_LOCAL_ONLY=0 → Tries Fable 5 (OpenCode Zen) first, falls back to local stylist
#
FORCE_LOCAL_ONLY=1

# OpenCode Zen / Fable 5 API (only needed if FORCE_LOCAL_ONLY=0)
ZEN_FABLE_URL=https://opencode.ai/zen/v1/chat/completions
ZEN_API_KEY=
